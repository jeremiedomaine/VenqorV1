# Supabase — projet Venqor V1 (vierge, dédié)
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Optionnel : migrations automatiques (Settings → Database → Connection string URI)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Emails transactionnels (Resend) — https://resend.com
RESEND_API_KEY=re_...
EMAIL_FROM=Venqor <notifications@venqor.app>

# Dev : redirige tous les emails couple + domaine vers cette adresse
EMAIL_TEST_OVERRIDE=jeremie.thomasse@gmail.com

# Cron Vercel — envoi auto solde J-30 (généré dans Vercel → Settings → Cron)
CRON_SECRET=changez-moi-en-prod

# Yousign — signature électronique (sandbox puis production)
YOUSIGN_API_KEY=
YOUSIGN_API_BASE=https://api-sandbox.yousign.app/v3
# Secret affiché dans Yousign → Webhooks (optionnel en dev local)
YOUSIGN_WEBHOOK_SECRET=

# Emails équipe Venqor (accès config contrat dans Paramètres)
VENQOR_ADMIN_EMAILS=jeremie.thomasse@gmail.com

# Gotenberg — conversion DOCX→PDF haute fidélité (optionnel ; repli Chrome intégré)
# docker run -p 3001:3000 gotenberg/gotenberg:8
# GOTENBERG_URL=http://localhost:3001
